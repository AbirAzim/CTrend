PORT=4000
NODE_ENV=development
# MongoDB Atlas (example — use your own user, password, cluster host)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/ctrend?retryWrites=true&w=majority
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated browser origins (Vite default 5173)
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000
# Same Web client ID as frontend VITE_GOOGLE_CLIENT_ID (for googleLogin)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Optional: only if you implement authorization-code flow on the server
# GOOGLE_CLIENT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Demo vote posts (CR7/Messi, iPhone/Android, etc.): auto in non-production; set true to allow in production
# SEED_DUMMY_POSTS=true
# SKIP_DUMMY_POSTS=true
