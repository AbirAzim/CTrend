PORT=4000
NODE_ENV=development
# MongoDB Atlas (example — use your own user, password, cluster host)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/ctrend?retryWrites=true&w=majority
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated browser origins (default in dev: allow all)
# CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
